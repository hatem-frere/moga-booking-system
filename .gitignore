# ============================================================
# Moga Booking System — .gitignore
# Author: Hatem Frere
# ============================================================


# ============================================================
# WordPress Core Files — Never commit these
# ============================================================
/wp-admin/
/wp-includes/


# ============================================================
# WordPress Config — Contains DB password, never commit
# ============================================================
wp-config.php
wp-config-sample.php


# ============================================================
# Uploads — User files, too large for Git
# ============================================================
/uploads/


# ============================================================
# WordPress Default Themes — Not our work
# ============================================================
/themes/twenty*/


# ============================================================
# WordPress Default Plugins — Not our work
# ============================================================
/plugins/akismet/
/plugins/hello.php
/plugins/hello-dolly/


# ============================================================
# Cache & Optimization Plugins Output
# ============================================================
/cache/
/w3tc-config/
/wp-rocket-config/


# ============================================================
# OS Files
# ============================================================

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~


# ============================================================
# IDE & Editor Files
# ============================================================

# VS Code
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json

# PhpStorm / JetBrains
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace


# ============================================================
# Node.js (if we add build tools later)
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json


# ============================================================
# Composer (PHP package manager)
# ============================================================
/vendor/
composer.lock


# ============================================================
# Log Files
# ============================================================
*.log
/logs/
debug.log
error_log


# ============================================================
# Environment Files — Contains secrets
# ============================================================
.env
.env.local
.env.production


# ============================================================
# Build Output
# ============================================================
/dist/
/build/


# ============================================================
# Backup Files
# ============================================================
*.bak
*.backup
*.sql
*.zip
*.tar.gz
*.rar